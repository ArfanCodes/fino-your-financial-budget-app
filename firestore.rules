rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: caller is signed-in ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: caller owns the document (existing doc) ──────────────────────
    // Used by expenses & categories (snake_case user_id field)
    function isOwner() {
      return request.auth.uid == resource.data.user_id;
    }

    // ── Helper: caller owns the document being written (new doc) ────────────
    // Used by expenses & categories (snake_case user_id field)
    function isWritingAsOwner() {
      return request.auth.uid == request.resource.data.user_id;
    }

    // ── Budget helpers (camelCase userId field) ───────────────────────────────
    function isBudgetOwner() {
      return request.auth.uid == resource.data.userId;
    }

    function isWritingBudgetAsOwner() {
      return request.auth.uid == request.resource.data.userId;
    }

    // ── Expenses ─────────────────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read,  delete: if isAuth() && isOwner();
      allow create:        if isAuth() && isWritingAsOwner();
      allow update:        if isAuth() && isOwner() && isWritingAsOwner();
    }

    // ── Categories ───────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read,  delete: if isAuth() && isOwner();
      allow create:        if isAuth() && isWritingAsOwner();
      allow update:        if isAuth() && isOwner() && isWritingAsOwner();
    }

    // ── Budgets ──────────────────────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read,  delete: if isAuth() && isBudgetOwner();
      allow create:        if isAuth() && isWritingBudgetAsOwner();
      allow update:        if isAuth() && isBudgetOwner() && isWritingBudgetAsOwner();
    }

    // ── Users (profile data) ────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }
  }
}
